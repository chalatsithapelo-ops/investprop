{
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.ts",
    "*.mjs",
    "*.cjs"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "app.config.timestamp_*"
  ],
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "moduleResolution": "Bundler",
    "skipLibCheck": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"]
    },
    "noEmit": true
  }
}
