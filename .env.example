# Node Environment
NODE_ENV=development

# Base URL (optional - defaults to localhost in development)
BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/property_investment_app

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production-min-32-chars
ADMIN_PASSWORD=admin123

# Email Service (optional)
EMAIL_SERVICE_API_KEY=
EMAIL_FROM_ADDRESS=noreply@propertyinvest.com
EMAIL_FROM_NAME=PropertyInvest

# AI Services (optional)
OPENROUTER_API_KEY=

# MinIO / S3 Storage
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
# If using docker/compose.yaml defaults:
#   MINIO_ACCESS_KEY=admin
#   MINIO_SECRET_KEY=${ADMIN_PASSWORD}
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=property-images
