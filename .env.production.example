# Investprop production env — copy to .env on the VPS and fill in real values.
# Generate secrets with: openssl rand -hex 48

# --- Public ---
BASE_URL=https://investprop.io
ACME_EMAIL=admin@investprop.io

# --- Postgres ---
POSTGRES_DB=investprop
POSTGRES_USER=investprop
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password

# --- Auth / JWT (>=32 chars each, use openssl rand -hex 48) ---
JWT_SECRET=CHANGE_ME_random_64_hex_chars
JWT_REFRESH_SECRET=CHANGE_ME_random_64_hex_chars_different
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password

# --- MinIO (object storage for property images) ---
MINIO_ACCESS_KEY=investprop
MINIO_SECRET_KEY=CHANGE_ME_strong_random_password
MINIO_BUCKET_NAME=property-images

# --- Optional integrations ---
OPENROUTER_API_KEY=
EMAIL_SERVICE_API_KEY=
EMAIL_FROM_ADDRESS=noreply@investprop.io
EMAIL_FROM_NAME=Investprop
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
