generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AIAnalysis {
  id           Int      @id @default(autoincrement())
  propertyId   Int
  analysis     String
  propertyType String
  generatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  property     Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int?
  action       String
  entity       String
  entityId     Int?
  changes      Json?
  oldValue     Json?
  newValue     Json?
  status       String? // SUCCESS | FAILED | DENIED
  errorMessage String?
  requestId    String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([entity, entityId])
  @@index([userId])
  @@index([action])
  @@index([status])
}

model BudgetEntry {
  id           Int        @id @default(autoincrement())
  propertyId   Int
  milestoneId  Int?
  amount       Float
  category     String
  description  String
  quotationUrl String?
  dateRecorded DateTime   @default(now())
  recordedById Int
  createdAt    DateTime   @default(now())
  milestone    Milestone? @relation(fields: [milestoneId], references: [id])
  property     Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  recordedBy   User       @relation(fields: [recordedById], references: [id])
}

model EmailVerification {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model InvestorContribution {
  id                   Int               @id @default(autoincrement())
  propertyId           Int
  investorId           Int
  contributionAmount   Float
  expectedReturnRate   Float
  expectedReturnAmount Float
  numberOfShares       Float? // Number of shares this investment buys
  sharePrice           Float? // Price per share at time of investment
  ownershipPercentage  Float? // Ownership % of the property
  status               String            @default("PENDING")
  paymentStatus        String            @default("NOT_PAID")
  paymentMethod        String?
  proofOfPaymentUrl    String?
  paymentReference     String?
  paymentSubmittedAt   DateTime?
  paymentReviewedAt    DateTime?
  paymentReviewedBy    Int?
  paymentReviewNotes   String?
  contributionDate     DateTime          @default(now())
  notes                String?
  reviewedAt           DateTime?
  coolingOffExpiresAt  DateTime?
  cancelledAt          DateTime?
  cancelledReason      String?
  deletedAt            DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime?         @updatedAt
  investor             User              @relation(fields: [investorId], references: [id])
  property             Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  certificate          ShareCertificate?

  @@index([createdAt])
  @@index([investorId])
  @@index([propertyId])
  @@index([status])
  @@index([paymentStatus])
  @@index([propertyId, investorId])
}

// ─── Share Certificates ─────────────────────────────────────────

model ShareCertificate {
  id                  Int                  @id @default(autoincrement())
  certificateNumber   String               @unique // Format: CERT-{propertyId}-{seq}-{year}
  contributionId      Int                  @unique
  propertyId          Int
  investorId          Int
  // ── Public fields (visible to investor) ──────────────────────
  investorName        String
  propertyTitle       String
  propertyAddress     String
  numberOfShares      Float
  sharePrice          Float
  totalValue          Float
  ownershipPercentage Float
  issueDate           DateTime             @default(now())
  shareClassName      String               @default("Ordinary")
  // ── Security & validation (internal only) ────────────────────
  validationHash      String               @unique // SHA-256 hash of certificate data for tamper detection
  internalFingerprint String               @unique // Secondary verification token (UUID v4)
  issuedById          Int // Manager who approved the payment
  isValid             Boolean              @default(true) // Can be revoked if fraud detected
  revokedAt           DateTime?
  revokedReason       String?
  revokedById         Int?
  // ── Internal tracking (never exposed to investor) ────────────
  internalNotes       String? // Admin-only notes
  fraudFlags          Int                  @default(0) // Fraud risk score (0 = clean)
  verificationCount   Int                  @default(0) // How many times it has been verified
  lastVerifiedAt      DateTime?
  lastVerifiedById    Int?
  ipAddressAtIssuance String? // IP when payment was confirmed
  auditTrail          Json? // Array of {action, userId, timestamp, details}
  downloadCount       Int                  @default(0) // Tracks how many times PDF has been downloaded
  downloadLog         Json? // Array of {copyNumber, downloadedBy, timestamp, documentSerial}
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @default(now()) @updatedAt
  // ── Relations ────────────────────────────────────────────────
  contribution        InvestorContribution @relation(fields: [contributionId], references: [id])
  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  investor            User                 @relation("InvestorCertificates", fields: [investorId], references: [id])

  @@index([propertyId])
  @@index([investorId])
  @@index([isValid])
  @@index([validationHash])
  @@index([internalFingerprint])
}

model Milestone {
  id                      Int                  @id @default(autoincrement())
  propertyId              Int
  name                    String
  description             String
  status                  MilestoneStatus      @default(PLANNED)
  estimatedStartDate      DateTime
  estimatedCompletionDate DateTime
  actualStartDate         DateTime?
  actualCompletionDate    DateTime?
  budgetAllocated         Float                @default(0)
  budgetSpent             Float                @default(0)
  order                   Int                  @default(0)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @default(now()) @updatedAt
  budgetEntries           BudgetEntry[]
  property                Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  progressSubmissions     ProgressSubmission[]
  rfqs                    RFQ[]
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      String
  category  String
  relatedId Int?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([userId, read])
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model ProgressSubmission {
  id             Int                      @id @default(autoincrement())
  milestoneId    Int
  submittedById  Int
  description    String
  imageUrls      Json
  approvalStatus SubmissionApprovalStatus @default(PENDING)
  rating         Int?
  reviewedById   Int?
  reviewNotes    String?
  reviewedAt     DateTime?
  submittedAt    DateTime                 @default(now())
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @default(now()) @updatedAt
  milestone      Milestone                @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  reviewedBy     User?                    @relation("ProgressSubmission_reviewedByIdToUser", fields: [reviewedById], references: [id])
  submittedBy    User                     @relation("ProgressSubmission_submittedByIdToUser", fields: [submittedById], references: [id])
}

model Property {
  id                        Int                      @id @default(autoincrement())
  title                     String
  description               String
  address                   String
  city                      String
  state                     String
  zipCode                   String
  price                     Float
  imageUrl                  String
  imageUrls                 Json? // Array of image URLs (multi-picture support)
  status                    PropertyStatus           @default(AVAILABLE)
  investmentStatus          InvestmentStatus         @default(PLANNING)
  fundingGoal               Float                    @default(0)
  fundingRaised             Float                    @default(0)
  fundingClosingDate        DateTime?
  fundingBreakdown          Json? // Array of {category: string, amount: number, description: string}
  isPublished               Boolean                  @default(false)
  minimumInvestment         Float                    @default(0) // Minimum investment amount in Rands
  maxInvestors              Int                      @default(50) // Companies Act §96(1)(b) — max 50 unique investors per SPV
  expectedReturns           Float                    @default(0) // Expected return rate as percentage
  // Phase 9: investor disclosures
  riskRating                PropertyRiskRating       @default(MEDIUM)
  documentsPackUrls         Json? // Array of {label, url} — MOI, valuation, SPV cert, sale agreement etc.
  // AI Strategy: independent underwriting + caching
  aiSummary                 String?                  @db.Text
  aiConfidenceRating        String? // A | B | C | D | E (Investprop Confidence Rating)
  aiConfidenceJustification String?                  @db.Text
  aiRiskScore               Float? // 0-100 platform risk score (independent of sponsor)
  aiUnderwriting            Json? // {comparables, stressTest, deviations, generatedAt}
  aiUnderwrittenAt          DateTime?
  aiListingScore            Int? // 0-100 listing quality (set by Listing Quality Coach)
  aiListingFeedback         Json? // {strengths, weaknesses, suggestions}
  bedrooms                  Int?
  bathrooms                 Int?
  squareMeters              Int?
  userId                    Int
  deletedAt                 DateTime?
  createdAt                 DateTime                 @default(now())
  aiAnalyses                AIAnalysis[]
  budgetEntries             BudgetEntry[]
  investorContributions     InvestorContribution[]
  milestones                Milestone[]
  user                      User                     @relation(fields: [userId], references: [id])
  propertyDevelopment       PropertyDevelopment?
  propertyFlip              PropertyFlip?
  rentalBond                RentalBond?
  riskEntries               RiskEntry[]
  spv                       SPV?                     @relation(fields: [spvId], references: [id])
  spvId                     Int?
  acquisition               Acquisition?
  shareClasses              ShareClass[]
  shareHoldings             ShareHolding[]
  shareLedgerEntries        ShareLedgerEntry[]
  distributions             Distribution[]
  proposals                 Proposal[]
  kycDocuments              KYCDocument[]
  legalDocuments            LegalDocument[]
  financialEntries          PropertyFinancialEntry[]
  shareCertificates         ShareCertificate[]
  rfqs                      RFQ[]
  workOrders                WorkOrder[]
  chatMessages              PropertyChatMessage[]
  photoChecks               ConstructionPhotoCheck[]
  updateDrafts              InvestorUpdateDraft[]
  distressPredictions       DistressPrediction[]
  distressedSource          DistressedListing?       @relation("PropertyFromDistressed")

  @@index([createdAt])
  @@index([investmentStatus])
  @@index([isPublished, fundingClosingDate])
  @@index([status])
  @@index([userId])
  @@index([spvId])
}

model PropertyDevelopment {
  id                         Int             @id @default(autoincrement())
  propertyId                 Int             @unique
  projectName                String
  totalBudget                Float
  spentBudget                Float           @default(0)
  startDate                  DateTime
  estimatedEndDate           DateTime
  actualEndDate              DateTime?
  numberOfUnits              Int
  landAcquisitionCost        Float           @default(0)
  hardCosts                  Float           @default(0)
  softCosts                  Float           @default(0)
  financingCosts             Float           @default(0)
  contingencyPercent         Float           @default(10)
  contingencyAmount          Float           @default(0)
  expectedSalePricePerUnit   Float           @default(0)
  totalExpectedRevenue       Float           @default(0)
  expectedProfit             Float           @default(0)
  expectedROI                Float           @default(0)
  expectedIRR                Float           @default(0)
  developmentTimelineMonths  Int             @default(0)
  preSaleUnits               Int             @default(0)
  costPerSquareMeter         Float           @default(0)
  totalSquareMeters          Int             @default(0)
  developmentType            DevelopmentType @default(AFFORDABLE_RESALE)
  expectedMonthlyRentPerUnit Float           @default(0)
  annualOperatingExpenses    Float           @default(0)
  stabilizedCapRate          Float           @default(0)
  expectedGrossYield         Float           @default(0)
  expectedNetYield           Float           @default(0)
  userId                     Int
  fundingGoal                Float           @default(0)
  createdAt                  DateTime        @default(now())
  property                   Property        @relation(fields: [propertyId], references: [id])
  user                       User            @relation(fields: [userId], references: [id])
}

model PropertyFlip {
  id                    Int       @id @default(autoincrement())
  propertyId            Int       @unique
  flipType              FlipType
  purchasePrice         Float
  renovationBudget      Float
  estimatedValue        Float
  actualValue           Float?
  profit                Float?
  completionDate        DateTime?
  holdingCosts          Float     @default(0)
  closingCostsPurchase  Float     @default(0)
  closingCostsSale      Float     @default(0)
  estimatedRepairCosts  Float     @default(0)
  afterRepairValue      Float     @default(0)
  maxOfferPrice         Float     @default(0)
  expectedROI           Float     @default(0)
  expectedProfitMargin  Float     @default(0)
  daysToComplete        Int       @default(0)
  totalInvestmentBudget Float     @default(0)
  spentInvestmentBudget Float     @default(0)
  fundingGoal           Float     @default(0)
  userId                Int
  createdAt             DateTime  @default(now())
  property              Property  @relation(fields: [propertyId], references: [id])
  user                  User      @relation(fields: [userId], references: [id])
}

model PropertyTemplate {
  id            Int      @id @default(autoincrement())
  userId        Int
  name          String
  propertyType  String
  configuration Json
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model RentalBond {
  id                        Int      @id @default(autoincrement())
  propertyId                Int      @unique
  bondAmount                Float
  monthlyRent               Float
  leaseStartDate            DateTime
  leaseEndDate              DateTime
  tenantName                String?
  tenantEmail               String?
  purchasePrice             Float    @default(0)
  annualPropertyTax         Float    @default(0)
  annualInsurance           Float    @default(0)
  monthlyHOAFees            Float    @default(0)
  monthlyMaintenanceReserve Float    @default(0)
  monthlyUtilities          Float    @default(0)
  monthlyManagementFee      Float    @default(0)
  vacancyRate               Float    @default(5)
  appreciationRate          Float    @default(3)
  capRate                   Float    @default(0)
  cashOnCashReturn          Float    @default(0)
  grossRentMultiplier       Float    @default(0)
  debtServiceCoverageRatio  Float    @default(0)
  grossYield                Float    @default(0)
  netYield                  Float    @default(0)
  downPaymentAmount         Float    @default(0)
  loanAmount                Float    @default(0)
  interestRate              Float    @default(0)
  loanTermYears             Int      @default(0)
  monthlyDebtService        Float    @default(0)
  totalInvestmentBudget     Float    @default(0)
  spentInvestmentBudget     Float    @default(0)
  fundingGoal               Float    @default(0)
  userId                    Int
  createdAt                 DateTime @default(now())
  property                  Property @relation(fields: [propertyId], references: [id])
  user                      User     @relation(fields: [userId], references: [id])
}

model RiskEntry {
  id             Int            @id @default(autoincrement())
  propertyId     Int
  title          String
  description    String
  severity       RiskSeverity
  likelihood     RiskLikelihood
  mitigationPlan String
  status         String         @default("ACTIVE")
  impactCost     Float          @default(0)
  createdById    Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  createdBy      User           @relation(fields: [createdById], references: [id])
  property       Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model User {
  id                         Int                      @id @default(autoincrement())
  email                      String                   @unique
  password                   String
  name                       String
  role                       UserRole
  investorCode               String?                  @unique // Unique investor ID e.g. IP-INV-00009
  investorPreferences        Json?
  createdAt                  DateTime                 @default(now())
  emailVerified              Boolean                  @default(false)
  updatedAt                  DateTime                 @default(now()) @updatedAt
  // Account lifecycle
  status                     UserStatus               @default(ACTIVE)
  approvedAt                 DateTime?
  approvedById               Int?
  suspendedAt                DateTime?
  suspendedById              Int?
  suspendedReason            String?
  // Token versioning — incrementing invalidates all outstanding refresh tokens
  tokenVersion               Int                      @default(0)
  // Compliance officer record (FSCA RE1/RE5 licensing)
  complianceOfficer          Boolean                  @default(false)
  complianceOfficerLicense   String?
  // FICA Verification
  ficaVerified               Boolean                  @default(false)
  ficaVerifiedAt             DateTime?
  ficaVerifiedById           Int?
  ficaExempt                 Boolean                  @default(false) // e.g. investments under R20,000 threshold
  ficaRejectedAt             DateTime?
  ficaRejectedReason         String?
  // KYC Profile (FICA personal details)
  idNumber                   String? // SA ID or passport number
  dateOfBirth                DateTime?
  phoneNumber                String?
  residentialAddress         String? // Full street address
  city                       String?
  province                   String?
  postalCode                 String?
  taxNumber                  String? // SARS tax reference (optional)
  companyName                String? // If investing via entity
  companyRegNumber           String? // CIPC registration number
  kycSubmittedAt             DateTime? // When the KYC form was submitted
  // Phase 10 — investor appropriateness questionnaire (FSCA suitability)
  appropriatenessCompletedAt DateTime?
  appropriatenessAssessment  Json? // {experience, income, netWorth, tolerance, ack flags, completedAt}
  // AI Strategy
  chatMessages               PropertyChatMessage[]
  portfolioInsights          PortfolioInsight[]
  investorUpdateDraftsSent   InvestorUpdateDraft[]    @relation("InvestorUpdateSentBy")
  aiUsageLogs                AIUsageLog[]
  auditLogs                  AuditLog[]
  budgetEntries              BudgetEntry[]
  emailVerifications         EmailVerification[]
  investorContributions      InvestorContribution[]
  notifications              Notification[]
  passwordResetTokens        PasswordResetToken[]
  reviewedSubmissions        ProgressSubmission[]     @relation("ProgressSubmission_reviewedByIdToUser")
  submittedSubmissions       ProgressSubmission[]     @relation("ProgressSubmission_submittedByIdToUser")
  properties                 Property[]
  propertyDevelopments       PropertyDevelopment[]
  propertyFlips              PropertyFlip[]
  propertyTemplates          PropertyTemplate[]
  refreshTokens              RefreshToken[]
  rentalBonds                RentalBond[]
  riskEntries                RiskEntry[]
  shareHoldings              ShareHolding[]
  shareLedgerEntries         ShareLedgerEntry[]
  kycDocuments               KYCDocument[]
  votes                      Vote[]
  spvDirectorships           SPV[]                    @relation("SPVDirector")
  financialEntries           PropertyFinancialEntry[]
  shareOrders                ShareOrder[]
  distributionPayouts        DistributionPayout[]
  distressedListings         DistressedListing[]
  ownerSaleProposals         OwnerSaleProposal[]      @relation("OwnerSaleProposals")
  reviewedSaleProposals      OwnerSaleProposal[]      @relation("ReviewedSaleProposals")
  shareCertificates          ShareCertificate[]       @relation("InvestorCertificates")
  contractorProfile          ContractorProfile?
  createdRFQs                RFQ[]
  issuedWorkOrders           WorkOrder[]              @relation("WorkOrderIssuedBy")
  ratedWorkOrders            WorkOrder[]              @relation("WorkOrderRatedBy")
  proposedVariations         VariationOrder[]         @relation("VariationProposedBy")
  approvedVariations         VariationOrder[]         @relation("VariationApprovedBy")
  workOrderUpdates           WorkOrderUpdate[]        @relation("WorkOrderUpdateSubmittedBy")
}

enum DevelopmentType {
  AFFORDABLE_RESALE
  AFFORDABLE_RENTAL
  COMMERCIAL_RENTAL
}

// ─── SPV & Acquisition Pipeline ───────────────────────────────────

model SPV {
  id                 Int             @id @default(autoincrement())
  name               String // e.g. "Investprop SPV 001 (Pty) Ltd"
  registrationNumber String? // CIPC registration number
  taxNumber          String? // SARS tax number
  status             SPVStatus       @default(PENDING_REGISTRATION)
  directorId         Int // Platform user who is the director
  registeredDate     DateTime?
  bankAccountNumber  String?
  bankName           String?
  bankBranchCode     String?
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @default(now()) @updatedAt
  director           User            @relation("SPVDirector", fields: [directorId], references: [id])
  properties         Property[]
  acquisitions       Acquisition[]
  legalDocuments     LegalDocument[]

  @@index([status])
  @@index([directorId])
}

model Acquisition {
  id                   Int            @id @default(autoincrement())
  propertyId           Int            @unique
  spvId                Int?
  acquiredByName       String // Name used at auction (personal or company)
  acquiredByType       AcquiredByType // PERSONAL, EXISTING_COMPANY, SPV
  auctionDate          DateTime
  auctionVenue         String?
  auctionType          String? // Sheriff, bank repo, private
  depositAmount        Float
  depositPaid          Boolean        @default(false)
  purchasePrice        Float
  transferDuty         Float          @default(0)
  conveyancingFees     Float          @default(0)
  cessionExecuted      Boolean        @default(false) // Has cession to SPV been done?
  cessionDate          DateTime?
  deedsOfficeRef       String? // Deeds Office reference number
  transferStatus       TransferStatus @default(AUCTION_WON)
  expectedTransferDate DateTime?
  actualTransferDate   DateTime?
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @default(now()) @updatedAt
  property             Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  spv                  SPV?           @relation(fields: [spvId], references: [id])

  @@index([transferStatus])
  @@index([spvId])
}

// ─── Fractional Ownership (Share Ledger) ─────────────────────────

model ShareClass {
  id                      Int                 @id @default(autoincrement())
  propertyId              Int
  name                    String              @default("Ordinary") // "Ordinary", "Preference", etc.
  totalShares             Int // Total shares available for this class
  pricePerShare           Float // Price per share in Rands
  minimumShares           Int                 @default(1) // Minimum shares per purchase
  minimumInvestmentAmount Float               @default(0) // Minimum investment in Rands (0 = no min)
  maxInvestors            Int? // Maximum number of investors allowed (null = unlimited)
  createdAt               DateTime            @default(now())
  property                Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  holdings                ShareHolding[]
  ledgerEntries           ShareLedgerEntry[]
  orders                  ShareOrder[]
  trades                  ShareTrade[]
  priceHistory            SharePriceHistory[]

  @@unique([propertyId, name])
  @@index([propertyId])
}

model ShareHolding {
  id                  Int        @id @default(autoincrement())
  propertyId          Int
  shareClassId        Int
  investorId          Int
  sharesOwned         Int
  averageCostPerShare Float
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @default(now()) @updatedAt
  property            Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  shareClass          ShareClass @relation(fields: [shareClassId], references: [id])
  investor            User       @relation(fields: [investorId], references: [id])

  @@unique([shareClassId, investorId])
  @@index([propertyId])
  @@index([investorId])
}

model ShareLedgerEntry {
  id              Int                  @id @default(autoincrement())
  propertyId      Int
  shareClassId    Int
  investorId      Int
  transactionType ShareTransactionType
  shares          Int // positive = buy/receive, negative = sell/transfer out
  pricePerShare   Float
  totalAmount     Float
  reference       String? // e.g. "Purchase", "Transfer from User X", "Distribution"
  balanceAfter    Int // Running balance of shares after this tx
  createdAt       DateTime             @default(now())
  property        Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  shareClass      ShareClass           @relation(fields: [shareClassId], references: [id])
  investor        User                 @relation(fields: [investorId], references: [id])

  @@index([propertyId])
  @@index([investorId])
  @@index([createdAt])
}

// ─── Distribution Engine ────────────────────────────────────────

model Distribution {
  id                Int                  @id @default(autoincrement())
  propertyId        Int
  type              DistributionType // RENTAL_INCOME, SALE_PROCEEDS, DIVIDEND, INTEREST
  taxClassification TaxClassification    @default(DIVIDEND)
  grossAmount       Float // Total income before fees
  managementFee     Float                @default(0) // Platform fee deducted
  netAmount         Float // Amount available for distribution
  period            String? // e.g. "2026-02" for monthly
  description       String?
  status            DistributionStatus   @default(PENDING)
  distributedAt     DateTime?
  deletedAt         DateTime?
  createdAt         DateTime             @default(now())
  property          Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payouts           DistributionPayout[]

  @@index([propertyId])
  @@index([status])
  @@index([createdAt])
}

model DistributionPayout {
  id                  Int          @id @default(autoincrement())
  distributionId      Int
  investorId          Int
  sharesAtTime        Int // Snapshot of shares held at distribution time
  percentageShare     Float // Their % of total shares
  grossAmount         Float
  taxWithheld         Float        @default(0)
  netAmount           Float // Amount paid to investor
  paymentRef          String? // Bank/payment reference
  status              PayoutStatus @default(PENDING)
  paidAt              DateTime?
  reconciledAt        DateTime?
  reconciliationNotes String?
  createdAt           DateTime     @default(now())
  distribution        Distribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  investor            User         @relation(fields: [investorId], references: [id])

  @@index([distributionId])
