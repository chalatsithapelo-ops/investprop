  issuedBy            User                @relation("WorkOrderIssuedBy", fields: [issuedById], references: [id])
  ratedBy             User?               @relation("WorkOrderRatedBy", fields: [ratedById], references: [id])
  invoices            ContractorInvoice[]
  updates             WorkOrderUpdate[]
  variations          VariationOrder[]

  @@index([propertyId])
  @@index([contractorProfileId])
  @@index([status])
}

