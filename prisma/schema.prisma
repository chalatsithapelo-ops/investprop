// ─── Distressed Property Finder ─────────────────────────────────

model DistressedListing {
  id            Int                     @id @default(autoincrement())
  externalId    String? // ID from source website
  source        String // e.g. "property24", "fnb_repos", "bidx1"
  sourceUrl     String? // original listing URL
  title         String
  description   String?
  propertyType  String // HOUSE, TOWNHOUSE, etc.
  address       String?
  suburb        String?
  city          String                  @default("Unknown")
  province      String                  @default("Gauteng")
  marketValue   Float? // estimated market value
  askingPrice   Float // auction reserve / asking price
  discount      Float? // percentage below market
  bedrooms      Int?
  bathrooms     Int?
  erfSize       Float? // in sqm
  floorSize     Float? // in sqm
  imageUrl      String?
  // Geo (for map view; populated lazily by geocoder)
  latitude      Float?
  longitude     Float?
  // AI screening (independent quick rating per listing)
  aiGrade       String? // A | B | C | D | E (Investprop quick screen)
  aiRiskScore   Float? // 0-100 (higher = more risk)
  aiSummary     String?                 @db.Text
  aiUnderwriting Json? // { pros, cons, redFlags, recommendations, comparableNotes }
  aiScoredAt    DateTime?
  // Dedup: same property listed on multiple sources gets same dedupGroupId
  dedupGroupId  String?
  // Promotion: link to Property record if this listing was converted into the pipeline
  convertedToPropertyId Int?            @unique
  convertedToProperty   Property?       @relation("PropertyFromDistressed", fields: [convertedToPropertyId], references: [id])
  convertedAt   DateTime?
  // Auction details
  auctionDate   DateTime?
  auctionTime   String? // e.g. "10:00 AM"
  auctionVenue  String?
  auctionType   String? // SHERIFF, BANK_REPO, LIQUIDATION, ONLINE
  auctioneer    String?
  noReserve     Boolean                 @default(false) // sold without reserve price
  caseNumber    String? // court case number (e.g. "2874/2023")
  courtDivision String? // e.g. "HIGH COURT GAUTENG DIVISION, PRETORIA"
  // Status tracking
  status        DistressedListingStatus @default(ACTIVE)
  isFavourited  Boolean                 @default(false)
  notes         String?
  addedById     Int?
  addedBy       User?                   @relation(fields: [addedById], references: [id])
  lastScrapedAt DateTime?
  // Reminder tracking (so we don't email the same person twice for the same trigger)
  remindersSent Json? // { auction7: ts, auction3: ts, auction1: ts, priceDropFromR: number }
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  priceHistory  DistressedListingPriceHistory[]

  @@unique([source, externalId])
  @@index([province, city])
  @@index([askingPrice])
  @@index([auctionDate])
  @@index([status])
  @@index([createdAt])
  @@index([dedupGroupId])
  @@index([aiGrade])
}

model DistressedListingPriceHistory {
  id          Int               @id @default(autoincrement())
  listingId   Int
  listing     DistressedListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  askingPrice Float
  marketValue Float?
  recordedAt  DateTime          @default(now())

  @@index([listingId, recordedAt])
}

model DistressedScrapeLog {
  id            Int      @id @default(autoincrement())
  source        String
  status        String // SUCCESS, PARTIAL, FAILED
  listingsFound Int      @default(0)
  newListings   Int      @default(0)
  errorMessage  String?
  durationMs    Int?
  scrapedAt     DateTime @default(now())
}

enum DistressedListingStatus {
  ACTIVE
  SOLD
  WITHDRAWN
  EXPIRED
  WATCHED
}

