}

enum EngagementType {
  OUTRIGHT_SALE // We buy the property outright
  JOINT_VENTURE // Owner contributes property as equity into a JV / SPV
  LEASE_BACK // We buy and rent back to owner
  DEVELOPMENT_PARTNERSHIP // We develop together, share returns
}

enum BondStatus {
  NONE
  EXISTING
}

enum RatesStatus {
  CURRENT
  ARREARS
}

enum TenancyStatus {
  OWNER_OCCUPIED
  TENANTED
  VACANT
}

enum PropertyCondition {
  EXCELLENT
  GOOD
  FAIR
  NEEDS_RENOVATION
  DISTRESSED
}

enum PropertyRiskRating {
  LOW
  MEDIUM
  HIGH
}

// ---------------------------------------------------------------
// AI Strategy models (Tier 1 � Tier 3)
// ---------------------------------------------------------------

model AIUsageLog {
  id               Int      @id @default(autoincrement())
  userId           Int?
  feature          String // chat | underwriting | doc-summary | listing-coach | portfolio | photo-check | distress | sponsor-track | update-draft | analyze-property
  model            String // e.g. openai/gpt-4o-mini
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  costUsd          Float    @default(0)
  latencyMs        Int      @default(0)
  status           String   @default("OK") // OK | ERROR | RATE_LIMITED
  errorMessage     String?
  metadata         Json?
  createdAt        DateTime @default(now())
  user             User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
}

model PropertyChatMessage {
  id         Int      @id @default(autoincrement())
  propertyId Int
  userId     Int
  role       String // user | assistant | system
  content    String   @db.Text
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([propertyId, userId, createdAt])
}

model PortfolioInsight {
  id          Int       @id @default(autoincrement())
  investorId  Int
  period      String // YYYY-MM
  summary     String    @db.Text
  insights    Json // [{type, severity, message, action?}]
  generatedAt DateTime  @default(now())
  dismissedAt DateTime?
  investor    User      @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([investorId, period])
  @@index([investorId, generatedAt])
}

model ConstructionPhotoCheck {
  id            Int      @id @default(autoincrement())
  propertyId    Int
  milestoneId   Int?
  submissionId  Int?
  photoUrls     Json // string[]
  expectedState String   @db.Text // what milestone claims
  verdict       String // GREEN | AMBER | RED
  confidence    Float    @default(0) // 0..1
  narrative     String   @db.Text
  flags         Json? // [{category, description}]
  generatedAt   DateTime @default(now())
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, generatedAt])
  @@index([milestoneId])
}

model InvestorUpdateDraft {
  id          Int       @id @default(autoincrement())
  propertyId  Int
  period      String // YYYY-MM
  subject     String
  bodyHtml    String    @db.Text
  bodyText    String    @db.Text
  status      String    @default("DRAFT") // DRAFT | SENT | CANCELLED
  sentAt      DateTime?
  sentById    Int?
  generatedAt DateTime  @default(now())
  property    Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  sentBy      User?     @relation("InvestorUpdateSentBy", fields: [sentById], references: [id])

  @@unique([propertyId, period])
  @@index([propertyId, status])
}

model DistressPrediction {
  id          Int      @id @default(autoincrement())
  propertyId  Int
  score       Float // 0..100, higher = more distressed risk
  band        String // LOW | MODERATE | ELEVATED | HIGH
  drivers     Json // [{factor, weight, value, narrative}]
  narrative   String   @db.Text
  generatedAt DateTime @default(now())
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, generatedAt])
  @@index([band])
}
