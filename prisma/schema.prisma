  contractorProfile   ContractorProfile @relation(fields: [contractorProfileId], references: [id])

  @@unique([rfqId, contractorProfileId])
  @@index([rfqId])
  @@index([contractorProfileId])
}

model WorkOrder {
  id                  Int                 @id @default(autoincrement())
  rfqId               Int?                @unique
  propertyId          Int
  contractorProfileId Int
  title               String
  description         String              @db.Text
  agreedAmount        Float
  startDate           DateTime
  expectedEndDate     DateTime
  actualEndDate       DateTime?
  status              WorkOrderStatus     @default(ISSUED)
  notes               String?
  issuedById          Int
  // Phase 12: acceptance + retention
  acceptedAt          DateTime?
  acceptedSignature   String? // Typed full name as e-signature
  retentionPercent    Float               @default(0) // Typical 5-10% for SA construction
  retentionAmount     Float               @default(0)
  retentionReleasedAt DateTime?
  hsFileUrl           String? // Health-and-safety file (OHS Act §37(2))
  completionRating    Int?
  completionNotes     String?             @db.Text
  ratedById           Int?
  ratedAt             DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @default(now()) @updatedAt
  rfq                 RFQ?                @relation(fields: [rfqId], references: [id])
