// ─── Governance / Voting ────────────────────────────────────────

model Proposal {
  id               Int            @id @default(autoincrement())
  propertyId       Int
  title            String
  description      String
  proposalType     ProposalType // SELL_PROPERTY, RENOVATE, CHANGE_TENANT, DISTRIBUTE, OTHER
