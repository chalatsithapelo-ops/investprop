  phone                  String
  address                String?
  city                   String?
  province               String?
  bankName               String?
  bankAccountNumber      String?
  bankBranchCode         String?
  insuranceExpiry        DateTime?
  cidbGrade              String? // CIDB grading (SA construction industry)
